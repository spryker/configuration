<input type="{% if setting.is_secret %}password{% else %}text{% endif %}"
       id="setting-{{ setting.key }}"
       class="form-control config-input"
       {% if setting.placeholder %}placeholder="{{ setting.placeholder }}"{% endif %}
       value="{{ setting.has_custom_value ? setting.current_value : setting.inherited_value }}"
       data-original-value="{{ setting.current_value }}"
       data-has-custom-value="{{ setting.has_custom_value ? '1' : '0' }}"
       {% if isEditable is defined and not isEditable %}disabled{% endif %}>
