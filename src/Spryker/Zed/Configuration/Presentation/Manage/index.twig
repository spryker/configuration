{% extends '@Gui/Layout/layout.twig' %}


{% block head_title %}
    {{ 'Configuration Management' | trans }}
{% endblock %}

{% block section_title %}
    {{ 'Settings' | trans }}
{% endblock %}

{% block head_css %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ assetsPath('css/spryker-zed-configuration-main.css') }}" />
{% endblock %}

{% block content %}

    {% if not isEditable %}
    <div class="alert alert-warning">
        <div class="alert__text">
            <i class="fa fa-lock"></i>
            {{ 'You do not have permission to edit configuration settings.' | trans }}
        </div>
    </div>
    {% endif %}

    <div class="configuration-management"
         data-scope="{{ currentScope }}"
         data-scope-identifier="{{ currentScopeIdentifier }}"
         data-read-only="{{ not isEditable ? '1' : '0' }}"
         data-i18n-reset-confirm="{{ 'Are you sure you want to reset all changes?' | trans | e('html_attr') }}"
         data-i18n-unsaved-scope-confirm="{{ 'You have unsaved changes. Do you want to discard them and switch scope?' | trans | e('html_attr') }}"
         data-i18n-unsaved-tab-confirm="{{ 'You have unsaved changes. Do you want to discard them and switch tabs?' | trans | e('html_attr') }}"
         data-i18n-dependent-reset-confirm-template="{{ 'Changing this setting will reset the following dependent settings:%newline%%settings%%newline%Do you want to continue?' | trans | e('html_attr') }}"
         data-i18n-save-error-prefix="{{ 'Error saving configuration: ' | trans | e('html_attr') }}"
         data-i18n-save-error-generic="{{ 'Error saving configuration. Please try again.' | trans | e('html_attr') }}"
         data-i18n-saving-label="{{ '<i class=&quot;fa fa-spinner fa-spin&quot;></i> %label%' | replace({'%label%': 'Saving...' | trans}) | e('html_attr') }}"
         data-i18n-save-label="{{ '<i class=&quot;fa fa-save&quot;></i> %label%' | replace({'%label%': 'Save Configuration' | trans}) | e('html_attr') }}">
        {# Top Bar: Scope Selector + Search #}
        <div class="config-top-bar">
            <div class="scope-selector">
                {% set nonGlobalScopes = availableScopes | filter(s => s != 'global') %}
                {% if nonGlobalScopes | length == 1 %}
                    {# Single non-global scope: combine scope type + identifier into one selector #}
                    {% set singleScope = nonGlobalScopes | first %}
                    {% set singleScopeIdentifiers = allScopeIdentifiers[singleScope] ?? [] %}
                    <select id="scope-combined" class="form-control" style="width: 200px; display: inline-block;">
                        <option value="global:" {% if currentScope == 'global' %}selected{% endif %}>
                            {{ ('Default (All ' ~ singleScope|capitalize ~ 's)') | trans }}
                        </option>
                        {% for identifier in singleScopeIdentifiers %}
                            <option value="{{ singleScope }}:{{ identifier }}" {% if currentScope == singleScope and identifier == currentScopeIdentifier %}selected{% endif %}>
                                {{ identifier }}
                            </option>
                        {% endfor %}
                    </select>
                {% else %}
                    {# Multiple non-global scopes: keep separate scope type + identifier selectors #}
                    <label for="scope-type">{{ 'Scope:' | trans }}</label>
                    <select id="scope-type" class="form-control" style="width: 150px; display: inline-block;">
                        {% for scope in availableScopes %}
                            <option value="{{ scope }}" {% if scope == currentScope %}selected{% endif %}>
                                {{ scope|capitalize }}
                            </option>
                        {% endfor %}
                    </select>

                    {% if scopeIdentifiers is not empty %}
                        <select id="scope-identifier" class="form-control" style="width: 150px; display: inline-block;">
                            {% for identifier in scopeIdentifiers %}
                                <option value="{{ identifier }}" {% if identifier == currentScopeIdentifier %}selected{% endif %}>
                                    {{ identifier }}
                                </option>
                            {% endfor %}
                        </select>
                    {% endif %}
                {% endif %}
            </div>

            <div class="config-search">
                <input type="text" id="config-search" class="form-control" placeholder="{{ 'Search settings...' | trans }}" style="width: 300px;">
            </div>
        </div>

        {# Main Layout: Sidebar + Content #}
        <div class="config-layout">
            {# Left Sidebar Navigation #}
            <div class="config-sidebar">
                <nav class="config-navigation">
                    {% for feature in navigationTree %}
                        <div class="nav-feature">
                            <div class="feature-header" data-feature="{{ feature.key }}">
                                <span class="side-menu__icon material-symbols-outlined">expand_more</span>
                                <span>{{ feature.name | trans }}</span>
                            </div>
                            <ul class="feature-tabs">
                                {% for tab in feature.tabs %}
                                    <li class="nav-tab {% if tab.key == selectedTab %}active{% endif %}"
                                        data-tab="{{ tab.key }}"
                                        data-feature="{{ feature.key }}">
                                        {% if tab.icon %}
                                            <span class="side-menu__icon material-symbols-outlined">{{ tab.icon }}</span>
                                        {% endif %}
                                        <span class="nav-label" data-qa="menu-item-label">{{ tab.name | trans }}</span>
                                    </li>
                                {% endfor %}
                            </ul>
                        </div>
                    {% endfor %}
                </nav>
            </div>

            {# Main Content Area #}
            <div class="config-content" id="config-content">
                {% for group in tabSettings %}
                    <div class="setting-group" data-group="{{ group.key }}">
                        <h3 class="group-header">{{ group.name | trans }}</h3>
                        {% if group.description %}
                            <p class="group-description">{{ group.description | trans }}</p>
                        {% endif %}

                        {% for setting in group.settings %}
                            {% include '@Configuration/Manage/_partials/setting-row.twig' %}
                        {% endfor %}
                    </div>
                {% endfor %}
            </div>
        </div>

        {% if isEditable %}
            {# Sticky Bottom Save Bar (hidden by default) #}
            <div class="config-save-bar" id="config-save-bar" style="display: none;">
                <div class="save-bar-content">
                    <span class="changes-count">
                        <i class="fa fa-exclamation-triangle"></i>
                        <span id="changes-count">0</span> {{ 'unsaved changes' | trans }}
                    </span>
                    <div class="save-bar-actions">
                        <button type="button" class="btn btn-default" id="reset-changes">
                            <i class="fa fa-undo"></i> {{ 'Reset Changes' | trans }}
                        </button>
                        <button type="button" class="btn btn-primary" id="save-configuration">
                            <i class="fa fa-save"></i> {{ 'Save Configuration' | trans }}
                        </button>
                    </div>
                </div>
            </div>
        {% endif %}
    </div>
{% endblock %}

{% block footer_js %}
    {{ parent() }}
    <script src="{{ assetsPath('js/spryker-zed-configuration-main.js') }}"></script>
{% endblock %}
