{% extends '@Gui/Layout/layout.twig' %}


{% block head_title %}
    {{ 'Configuration Management' | trans }}
{% endblock %}

{% block section_title %}
    {{ 'Settings' | trans }}
{% endblock %}

{% block head_css %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ assetsPath('css/spryker-zed-configuration-main.css') }}" />
{% endblock %}

{% block content %}
    {% if not isEditable %}
        <div class="alert alert-warning">
            <span class="material-symbols-outlined">lock_person</span>
            {{ 'You do not have permission to edit configuration settings.' | trans }}
        </div>
    {% endif %}

    <div class="configuration-management card"
         data-scope="{{ currentScope }}"
         data-scope-identifier="{{ currentScopeIdentifier }}"
         data-read-only="{{ not isEditable ? '1' : '0' }}"
         data-i18n-reset-confirm="{{ 'Are you sure you want to reset all changes?' | trans | e('html_attr') }}"
         data-i18n-unsaved-scope-confirm="{{ 'You have unsaved changes. Do you want to discard them and switch scope?' | trans | e('html_attr') }}"
         data-i18n-unsaved-tab-confirm="{{ 'You have unsaved changes. Do you want to discard them and switch tabs?' | trans | e('html_attr') }}"
         data-i18n-dependent-reset-confirm-template="{{ 'Changing this setting will reset the following dependent settings:%newline%%settings%%newline%Do you want to continue?' | trans | e('html_attr') }}"
         data-i18n-save-error-prefix="{{ 'Error saving configuration: ' | trans | e('html_attr') }}"
         data-i18n-save-error-generic="{{ 'Error saving configuration. Please try again.' | trans | e('html_attr') }}"
         data-i18n-saving-label="{{ '<i class=&quot;fa fa-spinner fa-spin&quot;></i> %label%' | replace({'%label%': 'Saving...' | trans}) | e('html_attr') }}"
         data-i18n-save-label="{{ '<i class=&quot;fa fa-save&quot;></i> %label%' | replace({'%label%': 'Save Configuration' | trans}) | e('html_attr') }}">
        {# Top Bar: Scope Selector + Search #}
        
        <div class="card-header">
            <div class="card-title">
                {{ 'Configuration Management' | trans }}
            </div>
            <div class="card-action card-action--expand">
                <button type="button" class="btn btn-primary config-open-menu-button" data-bs-toggle="offcanvas" data-bs-target="#config-sidebar" role="button" aria-controls="configSidebar">
                    <span class="material-symbols-outlined">settings</span>
                    {{ 'configuration.configure' | trans }}
                </button>

                {% include '@Configuration/Manage/_partials/scope-selector.twig' with {
                    availableScopes: availableScopes,
                } %}
            </div>
        </div>

        {# Main Layout: Sidebar + Content #}
        <div class="config-layout card-body">
            {# Left Sidebar Navigation #}
            <div class="config-sidebar offcanvas offcanvas-start" id="config-sidebar">
                <div class="js-scope-selector-placeholder"></div>

                <nav class="config-navigation">
                    {% for feature in navigationTree %}
                        <div class="nav-feature">
                            <div class="feature-header" data-feature="{{ feature.key }}" data-bs-toggle="collapse" data-bs-target="#{{ feature.key }}"{% if feature.description %} title="{{ feature.description | trans | e('html_attr') }}"{% endif %}>
                                <span class="side-menu__icon material-symbols-outlined">expand_more</span>
                                <span>{{ feature.name | trans }}</span>
                                {% include '@Configuration/Manage/_partials/status-badge.twig' with { status: feature.status } only %}
                            </div>
                            <ul class="feature-tabs collapse show" id="{{ feature.key }}">
                                {% for tab in feature.tabs %}
                                    <li class="feature-tabs__item js-nav-tab {% if tab.key == selectedTab and feature.key == selectedFeature %}active{% endif %}"
                                        data-tab="{{ tab.key }}"
                                        data-feature="{{ feature.key }}"
                                        {% if tab.description %}title="{{ tab.description | trans | e('html_attr') }}"{% endif %}>
                                        {% if tab.icon %}
                                            <span class="feature-tabs__icon material-symbols-outlined">{{ tab.icon }}</span>
                                        {% endif %}
                                        <span class="nav-label" data-qa="menu-item-label">{{ tab.name | trans }}</span>

                                        {% include '@Configuration/Manage/_partials/status-badge.twig' with { status: tab.status } only %}
                                    </li>
                                {% endfor %}
                            </ul>
                        </div>
                    {% endfor %}
                </nav>
            </div>

            {# Main Content Area #}
            <div class="config-content" id="config-content">
                {% for group in tabSettings %}
                    <div class="card setting-group" data-group="{{ group.key }}">
                        <div class="card-header d-block">
                            <h3 class="group-title">{{ group.name | trans }}{% include '@Configuration/Manage/_partials/status-badge.twig' with { status: group.status } only %}</h3>
                            
                            {% if group.description %}
                                <p class="group-description">{{ group.description | trans }}</p>
                            {% endif %}
                        </div>
                        <div class="card-body">
                            {% for setting in group.settings %}
                                {% include '@Configuration/Manage/_partials/setting-row.twig' %}
                            {% endfor %}
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>

        {% if isEditable %}
            <div class="config-save-bar" id="config-save-bar">
                <div class="save-bar-content">
                    <span class="changes-count">
                        <span class="material-symbols-outlined">warning</span>
                        <span id="changes-count">0</span> {{ 'unsaved changes' | trans }}
                    </span>
                    <div class="save-bar-actions">
                        <button type="button" class="btn btn-default" id="reset-changes" data-qa="reset-changes">
                            <span class="material-symbols-outlined">history</span>
                            {{ 'Reset Changes' | trans }}
                        </button>
                        <button type="button" class="btn btn-primary" id="save-configuration" data-qa="save-configuration">
                            <span class="material-symbols-outlined">save</span>
                            {{ 'Save Configuration' | trans }}
                        </button>
                    </div>
                </div>
            </div>
        {% endif %}
    </div>
{% endblock %}

{% block footer_js %}
    {{ parent() }}
    <script src="{{ assetsPath('js/spryker-zed-configuration-main.js') }}"></script>
{% endblock %}
